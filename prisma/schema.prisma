// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nama      String
  username  String   @unique
  password  String
  role      String   // "user" or "admin"
  nisn      String?
  kelas     String?

  // Relations
  aspirasi                  Aspirasi[]          @relation("UserAspirasi")
  admin_aspirasi            Aspirasi[]          @relation("AdminProses")
  progres_updates           ProgresUpdate[]
  notifikasi                Notifikasi[]
  chats                     Chat[]
  custom_chats_as_user      CustomChat[]        @relation("UserCustomChat")
  custom_chats_as_admin     CustomChat[]        @relation("AdminCustomChat")
  custom_chat_messages      CustomChatMessage[]

  @@map("users")
}

model Kategori {
  id             Int       @id @default(autoincrement())
  nama_kategori  String
  deskripsi      String?

  aspirasi Aspirasi[]

  @@map("kategori")
}

model Aspirasi {
  id              Int       @id @default(autoincrement())
  user_id         Int
  kategori_id     Int
  admin_id        Int?
  judul           String
  deskripsi       String
  lokasi          String
  foto_before     String?
  foto_after      String?
  nomor_tiket     String    @unique
  tanggal_input   DateTime  @default(now())
  tanggal_mulai   DateTime?
  tanggal_selesai DateTime?
  status          String    @default("pending") // pending, dalam_progres, selesai
  rating          Int?
  feedback        String?
  keterangan_selesai String?

  user            User           @relation("UserAspirasi", fields: [user_id], references: [id])
  kategori        Kategori       @relation(fields: [kategori_id], references: [id])
  admin           User?          @relation("AdminProses", fields: [admin_id], references: [id])
  progres_updates ProgresUpdate[]
  notifikasi      Notifikasi[]
  custom_chat     CustomChat?

  @@map("aspirasi")
}

model ProgresUpdate {
  id               Int      @id @default(autoincrement())
  aspirasi_id      Int
  admin_id         Int
  deskripsi_update String
  foto_url         String?  // Foto bukti progres (opsional)
  tanggal_update   DateTime @default(now())

  aspirasi Aspirasi @relation(fields: [aspirasi_id], references: [id], onDelete: Cascade)
  admin    User     @relation(fields: [admin_id], references: [id])

  @@map("progres_update")
}

model Notifikasi {
  id             Int      @id @default(autoincrement())
  penerima_id    Int
  jenis          String   // status_update | progres_update | custom_chat_message | custom_chat_new
  pesan          String
  aspirasi_id    Int?
  custom_chat_id Int?
  dibaca         Boolean  @default(false)
  tanggal_notif  DateTime @default(now())

  penerima    User        @relation(fields: [penerima_id], references: [id], onDelete: Cascade)
  aspirasi    Aspirasi?   @relation(fields: [aspirasi_id], references: [id], onDelete: SetNull)
  custom_chat CustomChat? @relation(fields: [custom_chat_id], references: [id], onDelete: SetNull)

  @@map("notifikasi")
}

model Chat {
  id              Int           @id @default(autoincrement())
  user_id         Int
  judul           String?
  dibuat_pada     DateTime      @default(now())
  diperbarui_pada DateTime      @updatedAt

  user     User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chats")
}

model ChatMessage {
  id          Int      @id @default(autoincrement())
  chat_id     Int
  role        String   // "user" or "assistant"
  konten      String
  dibuat_pada DateTime @default(now())

  chat Chat @relation(fields: [chat_id], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ─────────────────────────────────────────────
// Custom Chat (User ↔ Admin, dijawab manual oleh admin)
// ─────────────────────────────────────────────

model CustomChat {
  id              Int      @id @default(autoincrement())
  user_id         Int
  admin_id        Int?     // Admin yang ditugaskan menjawab
  aspirasi_id     Int?     @unique
  judul           String
  status          String   @default("open")   // open | in_progress | closed
  prioritas       String   @default("normal") // low | normal | high | urgent
  dibuat_pada     DateTime @default(now())
  diperbarui_pada DateTime @updatedAt

  user       User                @relation("UserCustomChat", fields: [user_id], references: [id], onDelete: Cascade)
  admin      User?               @relation("AdminCustomChat", fields: [admin_id], references: [id])
  aspirasi   Aspirasi?           @relation(fields: [aspirasi_id], references: [id], onDelete: SetNull)
  messages   CustomChatMessage[]
  notifikasi Notifikasi[]

  @@map("custom_chats")
}

model CustomChatMessage {
  id             Int      @id @default(autoincrement())
  custom_chat_id Int
  sender_id      Int
  sender_role    String   // "user" or "admin"
  konten         String
  foto_url       String?  // Foto lampiran (opsional)
  dibuat_pada    DateTime @default(now())

  custom_chat CustomChat @relation(fields: [custom_chat_id], references: [id], onDelete: Cascade)
  sender      User       @relation(fields: [sender_id], references: [id])

  @@map("custom_chat_messages")
}
